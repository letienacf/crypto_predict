{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "api.market.klines.response.v1",
  "title": "ApiMarketKlinesResponseV1",
  "type": "object",
  "additionalProperties": false,
  "required": ["status", "data"],
  "properties": {
    "status": { "const": "success" },
    "data": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["timestamp", "open", "high", "low", "close", "volume"],
        "properties": {
          "timestamp": { "type": "string", "format": "date-time" },
          "open": { "type": "number" },
          "high": { "type": "number" },
          "low": { "type": "number" },
          "close": { "type": "number" },
          "volume": { "type": "number" }
        }
      }
    }
  }
}
